@section Styles {
    <link rel="stylesheet" href="~/css/site_travel_details.css" />
}

@model Microtravel.Models.Travel

@{
    ViewData["Title"] = "Details";
}

<hr />
<div class="container mt-4">
    <div class="row justify-content-center" id="travelContainer">
        <div class="col-12 col-sm-8 col-md-6 col-lg-4">
                <div class="card w-100" style="box-shadow:2px 0px 8px #CCCCCC">
                    <img class="card-img-top img-fluid" src="@Model.travelPictureUrl" style="height:200px; object-fit:cover; width:100%;" alt="Card image cap">
                    <div class="card-body">
                        <h4 class="card-title text-center">@Model.Name</h4>
                        <hr />
                        <p class="card-title text-center">
                            @{
                                string utTipus = Model.TravelDealType.Name.ToLower() switch
                                {
                                    "autóbusz" => "Autóbuszos utazás",
                                    "repülő" => "Repülős utazás",
                                    "hajó" => "Hajós utazás",
                                    _ => Model.TravelDealType.Name + "út"
                                };
                            }
                            @utTipus
                        </p>
                        <hr />
                        <h6 class="card-title text-center" style="padding:8px 20px; color:white ;background-color:@(Model.TravelType.Name == "Normál" ? "green" : Model.TravelType.Name == "Last minute" ? "red" : "gray")">@Model.TravelType.Name</h6>
                        <hr />
                        <p class="card-text text-center">Indulás: @Model.TravelDate.ToString("yyyy.MM.dd")</p>
                        <p class="card-text text-break">@Model.Description</p>
                        <h5 class="text-center" style="    font-family: 'Montserrat', sans-serif !important;
                                font-weight: 500;
                                color: #266882;">
                            @Model.Price EUR
                        </h5>
                        <div class="text-center"><a href="#" class="btn btn-primary ">UTAZÁS FOGLALÁSA</a></div>
                    </div>
                </div>
            </div>
    </div>
</div>

<hr />
<div>
    <a asp-action="Travel" asp-controller="Travels">Vissza</a>
</div>
